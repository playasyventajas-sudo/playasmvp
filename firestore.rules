rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SDK / Console / import às vezes gravam números como float (5.0) ou string ("5").
    // O app (dataService) usa parseInt(trim(s)) em strings; a regra precisa aceitar os mesmos
    // casos — senão offerIssuedWhole vira 0 e o update anônimo exige couponsIssued == 1 em vez de N+1 → 403.
    function isWholeNumberLike(n) {
      return n is int
        || (n is float && int(n) == n)
        || (n is string && n.matches('^-?[0-9]+([.][0]+)?$'))
        || (n is string && n.matches('^\\s*-?[0-9]+([.][0]+)?\\s*$') && float(n) == int(float(n)));
    }
    function toWholeOrNeg1(n) {
      return n is int
        ? n
        : (n is float && int(n) == n
            ? int(n)
            : (n is string && n.matches('^-?[0-9]+([.][0]+)?$')
                ? int(n)
                : (n is string && n.matches('^\\s*-?[0-9]+([.][0]+)?\\s*$') && float(n) == int(float(n))
                    ? int(float(n))
                    : -1)));
    }
    function offerMaxCouponsWhole(data) {
      return data.keys().hasAny(['maxCoupons']) && toWholeOrNeg1(data.maxCoupons) >= 5
        ? toWholeOrNeg1(data.maxCoupons)
        : -1;
    }
    // Usar só toWholeOrNeg1 (>=0): evita divergência com isWholeNumberLike em formatos legados.
    function offerIssuedWhole(data) {
      return data.keys().hasAny(['couponsIssued']) && toWholeOrNeg1(data.couponsIssued) >= 0
        ? toWholeOrNeg1(data.couponsIssued)
        : 0;
    }

    match /offers/{offerId} {
      // Público: isActive boolean true, string "true" (Console/legado), ou sem campo (legado).
      // Com isActive == false, anônimo não lê. Dono lê todas as suas.
      allow read: if resource.data.isActive == true
        || resource.data.isActive == 'true'
        || resource.data.isActive == 1
        || !resource.data.keys().hasAny(['isActive'])
        || (request.auth != null && resource.data.ownerUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && (!request.resource.data.keys().hasAny(['maxCoupons'])
            || (isWholeNumberLike(request.resource.data.maxCoupons)
                && toWholeOrNeg1(request.resource.data.maxCoupons) >= 5
                && request.resource.data.couponsIssued == 0));
      allow update: if (request.auth != null && resource.data.ownerUid == request.auth.uid)
        || (request.auth == null
            && offerMaxCouponsWhole(resource.data) >= 5
            && offerIssuedWhole(resource.data) < offerMaxCouponsWhole(resource.data)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['couponsIssued', 'isActive'])
            && isWholeNumberLike(request.resource.data.couponsIssued)
            && toWholeOrNeg1(request.resource.data.couponsIssued) == offerIssuedWhole(resource.data) + 1
            // `affectedKeys` já garante que anônimo NÃO altera maxCoupons/ownerUid;
            // removemos comparações extras para tolerar documentos legados inconsistentes.
            && (request.resource.data.isActive == (toWholeOrNeg1(request.resource.data.couponsIssued) < offerMaxCouponsWhole(resource.data))
                || request.resource.data.isActive == false));
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
    // 1 cupom por combinação oferta + e-mail (dedupe atômico com o cupom).
    // get precisa ser permitido: a transação do cliente faz get(lock) antes do create.
    // list fica false para não vazar/varrer a coleção.
    match /couponLocks/{lockId} {
      allow get: if true;
      allow list: if false;
      allow create: if request.resource.data.keys().hasAll(['offerId', 'email', 'createdAt'])
        && request.resource.data.offerId is string
        && request.resource.data.email is string;
      allow update, delete: if false;
    }
    match /coupons/{couponId} {
      allow create: if request.resource.data.keys().hasAll(
          ['offerId','offerTitle','discount','userEmail','createdAt','status','merchantUid'])
        && request.resource.data.status == 'VALID'
        && request.resource.data.userEmail is string
        && request.resource.data.offerId is string
        && (request.resource.data.createdAt is int || request.resource.data.createdAt is float)
        && request.resource.data.merchantUid is string;
      // get: cupom inexistente → resource == null; a regra antiga lia resource.data e negava tudo (scanner quebrava).
      // list: só cupons do próprio comerciante (query com merchantUid alinha com a regra).
      allow get: if request.auth != null
        && (resource == null || resource.data.merchantUid == request.auth.uid);
      allow list: if request.auth != null
        && resource.data.merchantUid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.merchantUid == request.auth.uid
        && resource.data.status == 'VALID'
        && request.resource.data.status == 'USED';
    }
    match /companies/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Fila de e-mail (extensão "Trigger Email" do Firebase lê com privilégio de serviço)
    match /mail/{mailId} {
      allow create: if request.resource.data.keys().hasAll(['to', 'message'])
        && request.resource.data.to is list
        && request.resource.data.message is map
        && request.resource.data.message.keys().hasAll(['subject', 'html'])
        && request.resource.data.message.subject is string
        && request.resource.data.message.html is string;
      allow read, update, delete: if false;
    }
  }
}
