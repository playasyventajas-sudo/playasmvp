rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Atual: offers/{uid}/arquivo (uploadImage no dataService)
    match /offers/{ownerUid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }
    // Legado: offers/timestamp_nome.jpg (uma pasta só): leitura pública, sem novos writes
    match /offers/{legacyFile} {
      allow read: if true;
      allow write: if false;
    }
  }
}
